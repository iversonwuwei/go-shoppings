# Supabase Postgres
# 推荐使用 Supabase Dashboard 里的 Transaction pooler 或 Direct connection 连接串，保留 sslmode=require。
SUPABASE_DB_DSN=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_PREFER_SIMPLE_PROTOCOL=true

# Supabase Storage
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=wxmall
SUPABASE_STORAGE_PUBLIC_READ=true
SUPABASE_STORAGE_CREATE_BUCKET=true
SUPABASE_STORAGE_UPSERT=true
SUPABASE_STORAGE_SIGNED_URL_EXPIRES=604800

# WeChat mini program
WECHAT_APP_ID=wx2e1a62b7c57a5550
WECHAT_APP_SECRET=<wechat-mini-program-secret>

# App secrets
JWT_SECRET=change-this-secret-in-production

# Redis remains local by default. Docker Compose provides redis service as redis:6379.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
